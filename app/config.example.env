# Copy this file to .env and fill in real values locally.
# Do not commit real secrets.

# WeCom intelligent bot credentials
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# Optional allowlist, comma-separated. Example: user_a,user_b
WECOM_ALLOWED_USERS=

# Model provider settings
MODEL_PROVIDER=minimax-anthropic
MODEL_NAME=MiniMax-M2.7
MODEL_BASE_URL=https://api.minimaxi.com/anthropic
MODEL_API_KEY=
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=

# Storage root. Default planned value: data
M_AGENT_DATA_DIR=data

# 注意: ANTHROPIC_API_KEY 已移到标准配置
