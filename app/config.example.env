# Copy this file to .env and fill in real values locally.
# Do not commit real secrets.

# 运行环境：生产 Bot 只能从 main 启动。
M_AGENT_RUNTIME_ENV=production
# 开发分支真实联调时改为 test，并使用独立测试目录；不得与 M_AGENT_DATA_DIR 相同。
# M_AGENT_TEST_DATA_DIR=../M-Agent-Test-Files

# WeCom intelligent bot credentials
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# 当前写作入口生产凭据。
WRITING_BOT_ID=
WRITING_BOT_SECRET=

# 测试模式专用凭据。只填写需要联调的测试 Bot，不能填写生产值。
# M_AGENT_TEST_WRITING_BOT_ID=
# M_AGENT_TEST_WRITING_BOT_SECRET=
# M_AGENT_TEST_REVIEW_BOT_ID=
# M_AGENT_TEST_REVIEW_BOT_SECRET=
# M_AGENT_TEST_REWRITE_BOT_ID=
# M_AGENT_TEST_REWRITE_BOT_SECRET=
# M_AGENT_TEST_OPS_BOT_ID=
# M_AGENT_TEST_OPS_BOT_SECRET=

# 独立材料润色 Bot。该入口从注册表层只加载 rewrite，不接其他 Skill。
M_AGENT_REWRITE_BOT_ID=
M_AGENT_REWRITE_BOT_SECRET=
# 默认分别使用 tasks/writing/rewrite 和 runtime/conversations/rewrite-bot，一般无需覆盖。
# M_AGENT_REWRITE_JOBS_DIR=
# M_AGENT_REWRITE_CONVERSATION_DIR=

# Optional allowlist, comma-separated. Example: user_a,user_b
WECOM_ALLOWED_USERS=

# Model provider settings
MODEL_PROVIDER=minimax-anthropic
MODEL_NAME=MiniMax-M2.7
MODEL_BASE_URL=https://api.minimaxi.com/anthropic
MODEL_API_KEY=
M_AGENT_MODEL_MAX_TOKENS=4096
# 底座文档解析单文件上限；企业微信入口仍可设置更低的接收上限。
M_AGENT_DOCUMENT_MAX_MB=50
# 扫描 PDF 按需使用本机 OCR；macOS 默认回退到 Vision，不需要单独安装云端 OCR。
M_AGENT_DOCUMENT_OCR_ENABLED=true
# Direct report critic mode:
# advisory = 默认，仅提示质量风险，不因 critic 自动重写
# rewrite = critic 发现 hard 问题时自动重写一次
# off = 不运行 critic
M_AGENT_DIRECT_REPORT_CRITIC_MODE=advisory

# Legacy aliases kept for older modules. New writing/platform code reads MODEL_* first.
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=

# 搜索 API 独立配置（可选）。默认复用 MODEL_*：DeepSeek 通过 Anthropic Messages
# 的 web_search_20250305 原生联网搜索；只有显式使用独立搜索供应商时才覆盖下列两项。
# 未配置时依次回退到 MODEL_API_KEY/MODEL_BASE_URL、ANTHROPIC_API_KEY/ANTHROPIC_BASE_URL。
# SEARCH_API_KEY=
# SEARCH_API_BASE_URL=https://api.minimaxi.com/anthropic

# 非 Git 运行数据根目录。默认即项目同级的 M-Agent-Files；显式写出便于检查。
# 用户上传、系统生成、知识库、日志、会话和运维状态都从该目录派生。
M_AGENT_DATA_DIR=../M-Agent-Files
# 待组装文件默认保存在 M_AGENT_DATA_DIR/runtime/intake；一般无需单独覆盖。
# M_AGENT_INTAKE_DIR=
# 下列细分路径仅用于特殊部署覆盖，日常不需要配置：
# M_AGENT_PLATFORM_JOBS_DIR=
# M_AGENT_REVIEWS_DIR=
# M_AGENT_POLICY_DB_PATH=
# M_AGENT_BANK_DB_PATH=
# M_AGENT_CHAT_LOG_DIR=
# M_AGENT_CONVERSATION_DIR=
# M_AGENT_USER_REGISTRY_PATH=
# 持久化后台任务队列默认位于 runtime/task-execution/tasks.sqlite3；一般无需覆盖。
# M_AGENT_TASK_QUEUE_DB=
# 单项审核（文字、通用 Word、内参、半月报、公文格式）使用独立队列，避免写作 worker 误领。
# M_AGENT_REVIEW_TASK_DB=
M_AGENT_REVIEW_TASK_WORKERS=1
M_AGENT_REVIEW_TASK_POLL_SECONDS=0.25
M_AGENT_REVIEW_TASK_RECOVERY_SECONDS=5
M_AGENT_REVIEW_TASK_LEASE_SECONDS=120

# 写作 Bot 持久任务（直报、单素材简报、多素材简报）
# 使用独立 SQLite，避免审核 worker 误领取写作任务。
M_AGENT_WRITING_TASK_QUEUE_DB=../M-Agent-Files/runtime/task-execution/writing.sqlite3
M_AGENT_WRITING_TASK_WORKERS=1
M_AGENT_WRITING_TASK_POLL_SECONDS=0.25
M_AGENT_WRITING_TASK_RECOVERY_SECONDS=5
M_AGENT_WRITING_TASK_LEASE_SECONDS=120
# 审核公共日志和单用户日志按天记录，单文件达到该值后继续分片。
M_AGENT_LOG_MAX_MB=20
# 先复制 config/platform-policy.example.yaml 为本机文件，再填写实际用户权限。
M_AGENT_PLATFORM_POLICY=config/platform-policy.yaml

# 写作素材入口
# 默认只监听本机，避免未授权局域网设备访问开发期素材页。
# 如确需局域网访问，必须显式改为 0.0.0.0，并配置可访问地址，例如：
# M_AGENT_PORTAL_BASE_URL=http://192.168.1.23:8790
M_AGENT_PORTAL_HOST=127.0.0.1
M_AGENT_PORTAL_PORT=8790
M_AGENT_PORTAL_BASE_URL=
# 写作 Bot 短任务暂存时间：用于用户连续几条消息发送材料/意图后再开始写。
M_AGENT_WRITING_INTAKE_TTL=1800
# 审核 Bot 格式审核和多文件联合审核的暂存时间；默认目录为 runtime/intake/review。
M_AGENT_REVIEW_INTAKE_TTL=1800
# 连续 .docx 自动归为同一审核任务的后台静默窗口；每个文件仍会立即回复确认。
M_AGENT_REVIEW_AUTO_BATCH_SECONDS=8
# M_AGENT_REVIEW_INTAKE_DIR=

# 运维 Bot
# 独立长期运行，读取本地运维事件并向管理员发送异常通知和工作日日报。
M_AGENT_OPS_BOT_ID=
M_AGENT_OPS_BOT_SECRET=
M_AGENT_OPS_ADMIN_USER_ID=
# 默认从 M_AGENT_DATA_DIR/runtime/ops 派生，无需单独配置。
# M_AGENT_OPS_EVENTS_DIR=
# M_AGENT_OPS_STATE_PATH=
# M_AGENT_OPS_HEARTBEAT_DIR=
M_AGENT_OPS_HEARTBEAT_MAX_AGE_SECONDS=180
M_AGENT_OPS_MONITORED_SERVICES=writing_bot,review_bot
M_AGENT_OPS_DAILY_REPORT_HOUR=9
M_AGENT_OPS_DAILY_REPORT_MINUTE=0
M_AGENT_OPS_POLL_SECONDS=10
M_AGENT_OPS_NOTIFICATION_COOLDOWN=300

# 审核 Bot
# 企业微信 SDK 1.0.7 默认只等待 5 秒回复回执；大文件标注文档上传时可能不够。
# 审核 Bot 启动时会把 SDK 回执等待时间覆盖为该值，避免文件分片实际成功但被误判超时。
REVIEW_REPLY_ACK_TIMEOUT_SECONDS=30
# 默认由独立运维 Bot 发送详细告警；如需兼容旧模式，让审核 Bot 直接通知管理员，可改为 true。
REVIEW_DIRECT_ADMIN_NOTIFY=false

# 注意: 新写作/底座配置优先使用 MODEL_*，ANTHROPIC_* 仅保留兼容旧模块。
