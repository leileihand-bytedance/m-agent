# Copy this file to .env and fill in real values locally.
# Do not commit real secrets.

# WeCom intelligent bot credentials
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# Optional allowlist, comma-separated. Example: user_a,user_b
WECOM_ALLOWED_USERS=

# Model provider settings
MODEL_PROVIDER=minimax-anthropic
MODEL_NAME=MiniMax-M2.7
MODEL_BASE_URL=https://api.minimaxi.com/anthropic
MODEL_API_KEY=
M_AGENT_MODEL_MAX_TOKENS=4096
# Direct report critic mode:
# advisory = 默认，仅提示质量风险，不因 critic 自动重写
# rewrite = critic 发现 hard 问题时自动重写一次
# off = 不运行 critic
M_AGENT_DIRECT_REPORT_CRITIC_MODE=advisory

# Legacy aliases kept for older modules. New writing/platform code reads MODEL_* first.
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=

# Storage root. Default planned value: data
M_AGENT_DATA_DIR=data
M_AGENT_POLICY_DB_PATH=data/policy_knowledge/policies.sqlite3
M_AGENT_BANK_DB_PATH=data/bank_knowledge/bank.sqlite3
# 先复制 config/platform-policy.example.yaml 为本机文件，再填写实际用户权限。
M_AGENT_PLATFORM_POLICY=config/platform-policy.yaml

# 写作素材入口
# 默认只监听本机，避免未授权局域网设备访问开发期素材页。
# 如确需局域网访问，必须显式改为 0.0.0.0，并配置可访问地址，例如：
# M_AGENT_PORTAL_BASE_URL=http://192.168.1.23:8790
M_AGENT_PORTAL_HOST=127.0.0.1
M_AGENT_PORTAL_PORT=8790
M_AGENT_PORTAL_BASE_URL=
# 写作 Bot 短任务暂存时间：用于用户连续几条消息发送材料/意图后再开始写。
M_AGENT_WRITING_INTAKE_TTL=1800

# 运维 Bot
# 独立长期运行，读取本地运维事件并向管理员发送异常通知和工作日日报。
M_AGENT_OPS_BOT_ID=
M_AGENT_OPS_BOT_SECRET=
M_AGENT_OPS_ADMIN_USER_ID=
M_AGENT_OPS_EVENTS_DIR=data/platform/ops_events
M_AGENT_OPS_STATE_PATH=data/platform/ops_state.json
M_AGENT_OPS_HEARTBEAT_DIR=data/platform/heartbeats
M_AGENT_OPS_HEARTBEAT_MAX_AGE_SECONDS=180
M_AGENT_OPS_MONITORED_SERVICES=writing_bot,review_bot
M_AGENT_OPS_DAILY_REPORT_HOUR=9
M_AGENT_OPS_DAILY_REPORT_MINUTE=0
M_AGENT_OPS_POLL_SECONDS=10
M_AGENT_OPS_NOTIFICATION_COOLDOWN=300

# 审核 Bot
# 企业微信 SDK 1.0.7 默认只等待 5 秒回复回执；大文件标注文档上传时可能不够。
# 审核 Bot 启动时会把 SDK 回执等待时间覆盖为该值，避免文件分片实际成功但被误判超时。
REVIEW_REPLY_ACK_TIMEOUT_SECONDS=30
# 默认由独立运维 Bot 发送详细告警；如需兼容旧模式，让审核 Bot 直接通知管理员，可改为 true。
REVIEW_DIRECT_ADMIN_NOTIFY=false

# 注意: 新写作/底座配置优先使用 MODEL_*，ANTHROPIC_* 仅保留兼容旧模块。
