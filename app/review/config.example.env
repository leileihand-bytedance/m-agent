# Copy this file to a real `.env` and fill in real values locally.
# Do not commit real secrets.
#
# 启动前先:
#   cp app/review/config.example.env .env
#   vim .env   # 填入真实 Bot ID 和 Secret
#
# 启动审核 Bot:
#   python -m app.review.main
# 只检查配置(不连企微):
#   python -m app.review.main --check-config

# ============================================================
# 企微智能审核 Bot 凭证(独立 Bot,只做审核)
# ============================================================
WECOM_REVIEW_BOT_ID=
WECOM_REVIEW_BOT_SECRET=

# ============================================================
# 路径配置
# ============================================================
# 非 Git 运行数据根目录。用户原件、审核结果、日志和用户名表统一放在这里。
M_AGENT_DATA_DIR=../M-Agent-Files

# 规则库文件(Hermes 写入,审核 Bot 读取)
M_AGENT_REVIEW_RULES=app/data/rules.md

# 以下细分路径默认从 M_AGENT_DATA_DIR 派生，只有特殊部署才需要覆盖。
# M_AGENT_REVIEWS_DIR=
# M_AGENT_LOGS_DIR=
# M_AGENT_USER_REGISTRY_PATH=
# 单个审核日志文件上限，按天记录；达到上限后生成 part-002、part-003。
M_AGENT_LOG_MAX_MB=20

# ============================================================
# 管理员通知配置
# 当 Bot 出现异常时,会主动给这个企微用户发消息
# ============================================================
REVIEW_ADMIN_USER_ID=
REVIEW_ADMIN_NAME=

# 同一种异常通知的冷却时间(秒),默认 300
# REVIEW_NOTIFICATION_COOLDOWN=300

# 是否要求新用户先注册英文名(默认 false,后续开放权限时可改为 true)
# REVIEW_REQUIRE_REGISTRATION=false

# ============================================================
# 审核模块专用模型配置(推荐单独配置,避免影响写作等其他入口)
# DeepSeek Anthropic 兼容接入文档:
# https://api-docs.deepseek.com/zh-cn/guides/anthropic_api
# ============================================================
REVIEW_MODEL_PROVIDER=deepseek-anthropic
REVIEW_MODEL_NAME=deepseek-v4-flash
REVIEW_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
REVIEW_ANTHROPIC_API_KEY=
