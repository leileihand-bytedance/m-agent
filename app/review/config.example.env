# Copy this file to a real `.env` and fill in real values locally.
# Do not commit real secrets.
#
# 启动前先:
#   cp app/review/config.example.env .env
#   vim .env   # 填入真实 Bot ID 和 Secret
#
# 启动审核 Bot:
#   python -m app.review.main
# 只检查配置(不连企微):
#   python -m app.review.main --check-config

# ============================================================
# 企微智能审核 Bot 凭证(独立 Bot,只做审核)
# ============================================================
WECOM_REVIEW_BOT_ID=
WECOM_REVIEW_BOT_SECRET=

# ============================================================
# 路径配置
# ============================================================
# 规则库文件(Hermes 写入,审核 Bot 读取)
M_AGENT_REVIEW_RULES=app/data/rules.md

# 审核结果存档目录
M_AGENT_REVIEWS_DIR=data/reviews
